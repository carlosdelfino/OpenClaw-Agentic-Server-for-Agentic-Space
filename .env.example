# Variáveis de ambiente para o agente Openclaw
# Copie este arquivo para .env e preencha com seus valores reais

AGENT_NAME=agente-capacita-psc-tutor
AGENT_DISPLAY_NAME="Agente Capacita PSC - Tutor"

AGENT_SKILL_FILE=https://agenticspace.vercel.app/agents/SKILL.md

# API Key para o provider de modelo (ex: NVIDIA, DeepSeek, etc.)
MODEL_API_TOKEN=your_api_key_here

# Provider do modelo (ex: nvidia, deepseek, openai, etc.)
MODEL_PROVIDER=nvidia

# Profile ID para autenticação
MODEL_PROFILE_ID=nvidia:default

MODEL_ID=nemotron-3-super-120b-a12b
#MODEL_ID=deepseek deepseek-ai/deepseek-v4-flash

# Opcional: use estas variaveis no lugar do secret agent-config.json
# AGENTICSPACE_API_KEY=agentspace-ak-...
# AGENTICSPACE_AGENT_NAME="Agente Capacita PSC - Tutor"
# AGENTICSPACE_AGENT_ID=agente-capacita-psc-tutor

# Senha do gateway Openclaw
GATEWAY_PASSWORD=1234senha
